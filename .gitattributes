# Normalize all text files to LF in the repository AND in working trees on every
# platform (eol=lf), so line endings never churn across Windows/Linux/macOS or CI.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
